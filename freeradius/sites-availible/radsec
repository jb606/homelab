# Listen Section
listen {
    ipaddr = *
    port = 2083
    type = auth+acct
    proto = tcp
    clients = radsec-clients
    #clients = dynamic
    tls {
        private_key_file = ${certdir}/labserver.key
        certificate_file = ${certdir}/labserver.crt
        ca_file = ${cadir}/ca.crt
        cipher_list = "HIGH:!aNULL:!eNULL:!MD5:!SHA1"
        
        # STIG compliance: Disable older TLS versions
        #min_version = "1.2"
        
        # Ensure 'require_client_cert' is yes for mutual TLS
        require_client_cert = yes
    }
    virtual_server = radsec
}
# End listen

clients radsec-clients {
  client dynamic {
    ipaddr = 172.16.160.0/20
    proto = tls
    lifetime = 3600
  }
}


server radsec {
authenticate {
  eap
}
authorize {
  preprocess

  # We are going to use the Tmp-String-0 helper to setup our mac address to be in xx:xx:xx:xx:xx:xx format
  if (&Calling-Station-Id && (&Calling-Station-Id =~ /^${policy.mac-addr-regexp}$/i)) {
    update request {
      &Calling-Station-Id := "%{toupper:%{1}-%{2}-%{3}-%{4}-%{5}-%{6}}"
      &Tmp-String-0 := "%{1}:%{2}:%{3}:%{4}:%{5}:%{6}"
    }
    updated
  } else {
    noop
  }
 
  

  # MAC SEC Section 
  if (!EAP-Message) {
    ldap_macsec
    if (!&control:LDAP-UserDN) {
      reject
    }
    update reply {
      Message-Authenticator := 0x00
    }
    update control {
      Auth-Type := Accept
    }
    
  }
  if (EAP-Message) {
    # Query ldap (mods-enabled/ldap) for the computer/device object.  
    # Device must have a name and mac!
    ldap_radsec
    # This will kick the device out if we didn't add it because
    # it didn't have an LDAP entry
    if (!&control:LDAP-UserDN) {
      reject
    }
    # See modules-enabled/eap
    eap
  }
  # Kick the client if it didn't authenticate
  if (!&control:Auth-Type) {
    reject
  }
