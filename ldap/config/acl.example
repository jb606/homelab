dn: olcDatabase={1}mdb,cn=config
changetype: modify
replace: olcAccess
olcAccess: {0}to attrs=userPassword
  by group.exact="cn=ldapadmins,ou=Groups,dc=example,dc=lab" write
  by self write
  by anonymous auth
  by * none
olcAccess: {1}to attrs=shadowLastChange,authTimestamp,pwdAccountLockedTime
  by group.exact="cn=ldapadmins,ou=Groups,dc=example,dc=lab" write
  by self write
  by * read
olcAccess: {2}to dn.subtree="ou=People,dc=example,dc=lab"
  by group.exact="cn=ldapadmins,ou=Groups,dc=example,dc=lab" write
  by users read
  by anonymous auth
olcAccess: {3}to dn.subtree="ou=Groups,dc=example,dc=lab"
  by group.exact="cn=ldapadmins,ou=Groups,dc=example,dc=lab" write
  by users read
  by anonymous auth
olcAccess: {4}to *
  by users read
  by anonymous auth
